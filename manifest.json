{
  "name": "自动下载youtube视频",
  "description" : "每45秒刷新youtube的订阅页面, 判断前N个视频是否已经被下载, 如果没有被下载则: 自动触发 downie 下载视频",
  "version": "3.0.0",
  "background": {
      "service_worker": "background.js"
  },
  "manifest_version": 3,
  "permissions": [
      "activeTab",
      "storage"
  ],
  "action": {
    "default_icon": {
       "16": "auto-download-youtube.png",
       "48": "auto-download-youtube.png",
       "128": "auto-download-youtube.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "auto-download-youtube.png",
    "32": "auto-download-youtube.png",
    "48": "auto-download-youtube.png",
    "128": "auto-download-youtube.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.google.com/sorry/index?continue=*"
      ],
      "js":[
         "jquery.min.js",
         "jquery.md5.js",
         "autoDownload.js"
      ],
      "css": [
      ]
    }
  ]
}
